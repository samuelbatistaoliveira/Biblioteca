<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C1208"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1976D2"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#1976D2"
            app:title="ADMINISTRADOR"
            app:titleTextColor="#F0F4F8" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvSalaTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sala A, Andar 1"
                android:textColor="#1A1A1A "
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvCapacidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cap. 6 pessoas"
                android:textColor="#757575"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_badge_livre"
                android:paddingHorizontal="16dp"
                android:paddingVertical="5dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVRE"
                    android:textColor="#1976D2"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D9C9A8"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gerenciar Horários"
                android:textColor="#3B2A0E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:paddingBottom="12dp" />

            <!-- TURNO 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F0F4F8"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/iconTurno1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1º TURNO"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="07:30 às 09:10"
                            android:textColor="#1A1A1A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTurno1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        android:contentDescription="Liberar turno 1" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TURNO 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F0F4F8"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/iconTurno2"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2º TURNO"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09:30 às 11:10"
                            android:textColor="#1A1A1A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTurno2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        android:contentDescription="Liberar turno 2" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TURNO 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F0F4F8"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/iconTurno3"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3º TURNO"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11:20 às 13:00"
                            android:textColor="#1A1A1A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTurno3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        android:contentDescription="Liberar turno 3" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TURNO 4 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F0F4F8"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/iconTurno4"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4º TURNO"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="13:30 às 15:10"
                            android:textColor="#1A1A1A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTurno4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        android:contentDescription="Liberar turno 4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TURNO 5 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F0F4F8"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/iconTurno5"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_calendar"
                        android:padding="6dp"
                        android:background="@drawable/circle_gold_bg"
                        android:contentDescription="Horário"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5º TURNO"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:paddingBottom="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15:30 às 17:10"
                            android:textColor="#1A1A1A"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:fontFamily="serif" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTurno5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:thumbTint="@color/switch_thumb_color"
                        app:trackTint="@color/switch_track_color"
                        android:contentDescription="Liberar turno 5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BOTÃO SALVAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="SALVAR ALTERAÇÕES"
                android:textColor="#F2EAD8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/button_gold_background"
                app:backgroundTint="@null"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="64dp"
        android:background="#2A2A2A" />


    <!-- BOTTOM NAV ADMIN -->
    <include
        layout="@layout/bottom_nav_admin"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>