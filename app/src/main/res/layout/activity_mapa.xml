<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FDF8F2">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biblioteca Digital"
            android:textColor="#C9A84C"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Mapa da Biblioteca"
            android:textColor="#2C1F0E"
            android:textSize="20sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

    </LinearLayout>




    <!-- BOTTOM NAV ADMIN -->
    <include layout="@layout/bottom_nav_admin" />

    <!-- RESULTADO DA BUSCA -->
    <LinearLayout
        android:id="@+id/layoutResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_banner_info"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_signpost"
            android:contentDescription="Seção"
            app:tint="#C9A84C"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Localizado em: Seção X"
            android:textColor="#2C1F0E"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- MAPA -->
    <!-- MAPA -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/imgMapa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/planta_biblioteca"
            android:contentDescription="Mapa da Biblioteca"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:layout_margin="12dp" />

    </androidx.core.widget.NestedScrollView>



    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconChat"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chat"
                android:contentDescription="Menu"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconHome"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Início"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReservas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconReservas"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_calendar"
                android:contentDescription="Reservas"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconSalas"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_signpost"
                android:contentDescription="Salas"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iconPerfil"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Perfil"
                app:tint="@color/bottom_nav_icon_color" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>